# Copy this file to .env and fill in your key. .env is git-ignored.
# Required - the app will not start without this.
ODDS_API_KEY=
# Comma-separated sport keys to pull live moneyline odds for (see https://the-odds-api.com/sports-odds-data/sports-apis.html)
ODDS_API_SPORTS=americanfootball_nfl,soccer_fifa_world_cup
# Comma-separated allowed origins for CORS. Leave empty unless the frontend
# is deployed on a different domain than this backend.
ALLOWED_ORIGINS=

# Required - secret used to sign login sessions. Any long random string.
JWT_SECRET=
# Database connection string. Defaults to a local SQLite file if unset.
DATABASE_URL=sqlite:///./app.db

# Stripe (test mode). Get these from https://dashboard.stripe.com/test/apikeys
# and a test Product+Price you create yourself. Billing endpoints return a
# clear 503 until these are set — everything else works without them.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:5173

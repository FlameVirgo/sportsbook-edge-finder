# Copy this file to .env and fill in your key. .env is git-ignored.
# Required - the app will not start without this.
ODDS_API_KEY=
# Comma-separated sport keys to pull live moneyline odds for (see https://the-odds-api.com/sports-odds-data/sports-apis.html)
ODDS_API_SPORTS=americanfootball_nfl,basketball_nba,soccer_epl
